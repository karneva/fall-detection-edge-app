# Camera
CAM_INDEX=0
CAM_DEVICE=
FRAME_W=1920
FRAME_H=1080
JPEG_QUALITY=80

# YOLO / inference
MODEL_PATH=yolov8s-pose.pt
DEFAULT_CONF=0.50
DETERMINISTIC=1
USE_HALF=0

# Device identity
DEVICE_ID=EEUM-J105
DEVICE_NAME=Jetson-Orin-Nano
LOCATION_ID=LivingRoom

# Backend / network
SERVER_URL=https://your-backend.example.com
WS_SERVER_URL=
RPI_URL=http://10.10.0.1:8080/eeum

# Runtime storage
RUNS_DIR=/app/runs
CLIP_DIR=/app/runs/clips

# Clip recording
CLIP_FPS=24
CLIP_RESIZE_WIDTH=640
CLIP_RESIZE_HEIGHT=480
CLIP_PRE_SEC=6
CLIP_POST_SEC=6
CLIP_COOLDOWN_S=30.0

# Fall detection
ABNORMAL_TIMEOUT_S=10.0

# EMA smoothing
KP_EMA_ENABLE=1
KP_EMA_ALPHA=0.5
KP_MIN_CONF=0.30
